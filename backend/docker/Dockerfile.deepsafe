FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    git \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/siddharthksah/DeepSafe.git /app/deepsafe

WORKDIR /app/deepsafe

RUN pip install --no-cache-dir -r requirements.txt 2>/dev/null || true

EXPOSE 8001

CMD ["python", "app.py"]
